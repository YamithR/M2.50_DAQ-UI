#:kivy 2.3
#:import BleDeviceItem widgets.ble_device_item.BleDeviceItem

<BleDeviceItem>:
    orientation: 'horizontal'
    size_hint_y: None
    height: dp(56)
    padding: dp(8)
    spacing: dp(8)
    canvas.before:
        Color:
            rgba: 0.07, 0.07, 0.07, 1
        Rectangle:
            pos:  self.pos
            size: self.size

    Label:
        text: root.device_name
        font_name: 'RobotoMono-Regular'
        font_size: sp(13)
        color: 0.3, 0.33, 0.125, 1
        text_size: self.size
        halign: 'left'
        valign: 'middle'

    Label:
        text: root.device_rssi
        font_size: sp(11)
        color: 0.55, 0.55, 0.55, 1
        size_hint_x: None
        width: dp(80)

    Button:
        text: 'CONECTAR'
        size_hint_x: None
        width: dp(100)
        font_size: sp(11)
        background_color: 0.293, 0.325, 0.125, 1
        on_release: app.root.get_screen('scan').connect_to(root.address)


<BtScanScreen>:
    name: 'scan'
    canvas.before:
        Color:
            rgba: 0.043, 0.043, 0.043, 1
        Rectangle:
            pos:  self.pos
            size: self.size

    BoxLayout:
        orientation: 'vertical'
        padding: dp(16)
        spacing: dp(12)

        Label:
            text: 'M2.50 DAQ — BLUETOOTH SCAN'
            font_size: sp(16)
            bold: True
            color: 0.293, 0.325, 0.125, 1
            size_hint_y: None
            height: dp(40)

        Button:
            id: btn_scan
            text: 'ESCANEAR'
            size_hint_y: None
            height: dp(50)
            font_size: sp(14)
            background_color: 0.293, 0.325, 0.125, 1
            on_release: root.do_scan()

        Label:
            text: 'Dispositivos M2-DAQ encontrados:'
            font_size: sp(12)
            color: 0.55, 0.55, 0.55, 1
            size_hint_y: None
            height: dp(28)
            halign: 'left'
            text_size: self.size

        RecycleView:
            id: rv
            data: []
            viewclass: 'BleDeviceItem'
            RecycleBoxLayout:
                orientation: 'vertical'
                default_size:   None, dp(56)
                default_size_hint: 1, None
                size_hint_y: None
                height: self.minimum_height
                spacing: dp(2)
